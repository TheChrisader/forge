{
  "name": "forge",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Local-first application deployment platform",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "main": "index.js",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run tests/integration",
    "test:unit": "vitest run packages",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "clean": "turbo run clean && shx rm -rf node_modules",
    "db:generate": "pnpm --filter @forge/database db:generate",
    "db:migrate": "pnpm --filter @forge/database db:migrate",
    "db:studio": "pnpm --filter @forge/database db:studio",
    "db:reset": "pnpm --filter @forge/database db:reset",
    "db:seed": "pnpm --filter @forge/database db:seed",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:ps": "docker-compose ps",
    "setup:certs": "tsx tools/scripts/setup-certs.ts",
    "test:queue": "pnpm --filter @forge/queue test:connection",
    "test:cache": "pnpm --filter @forge/cache test:connection",
    "forge": "pnpm --filter @forge/cli start"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.28.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@forge/database": "workspace:*",
    "@forge/docker": "workspace:*",
    "@forge/queue": "workspace:*",
    "@forge/storage": "workspace:*",
    "@forge/test-utils": "workspace:*",
    "@testcontainers/postgresql": "^11.11.0",
    "@testcontainers/redis": "^11.11.0",
    "@types/node": "^25.2.0",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "fastify": "^5.7.4",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "shx": "^0.4.0",
    "supertest": "^7.2.2",
    "testcontainers": "^11.11.0",
    "tsx": "^4.21.0",
    "turbo": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@forge/certificate": "workspace:*",
    "@types/web-push": "^3.6.4",
    "web-push": "^3.6.7"
  }
}
