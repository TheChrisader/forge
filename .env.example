# Environment
NODE_ENV=development

# Server
PORT=4000
HOST=localhost
CORS_ENABLED=true
CORS_ORIGINS=*
CORS_CREDENTIALS=true

# Database
DATABASE_URL=postgresql://forge:forge_dev_password@localhost:5432/forge?schema=public
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_SSL=false
DB_LOGGING=false

# Redis (for cache and queue)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=forge_dev_password
REDIS_DB=0

# Cache (@forge/cache)
CACHE_PROVIDER=redis
CACHE_TTL=3600

# Queue (@forge/queue)
QUEUE_HOST=localhost
QUEUE_PORT=6379
QUEUE_PASSWORD=forge_dev_password
QUEUE_DB=1
QUEUE_JOB_ATTEMPTS=3
QUEUE_BACKOFF_TYPE=exponential
QUEUE_BACKOFF_DELAY=5000
QUEUE_REMOVE_ON_COMPLETE=10
QUEUE_REMOVE_ON_FAIL=50

# Docker
DOCKER_SOCKET=/var/run/docker.sock
DOCKER_NETWORK=forge-network

# Storage
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./data

# Proxy
PROXY_PROVIDER=traefik
PROXY_HTTP_PORT=80
PROXY_HTTPS_PORT=443
PROXY_DOMAIN=local.dev

# Observability
LOGS_ENABLED=true
LOG_LEVEL=INFO
LOG_RETENTION=30d
LOG_FORMAT=json
METRICS_ENABLED=true
METRICS_INTERVAL=10000
TRACING_ENABLED=false

# Security
JWT_SECRET=your-secret-key-min-32-characters-long-replace-this
SECRETS_ENCRYPTION_KEY=your-encryption-key-min-32-chars

# Features
FEATURE_AUTO_SSL=true
FEATURE_IMAGE_SCAN=true
FEATURE_MULTI_USER=false
FEATURE_PLUGINS=true
FEATURE_WEB_SEARCH=false
FEATURE_HOT_RELOAD=true

# Paths
PATH_DATA=./data
PATH_LOGS=./logs
PATH_BUILDS=./builds
PATH_CACHE=./cache
PATH_PLUGINS=./plugins
PATH_TEMP=./tmp
