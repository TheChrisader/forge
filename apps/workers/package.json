{
  "name": "@forge/workers",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "start:builder": "node dist/builder/index.js",
    "start:deployer": "node dist/deployer/index.js",
    "start:observer": "node dist/observer/index.js",
    "start:scheduler": "node dist/scheduler/index.js",
    "clean": "shx rm -rf dist",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "bin": {
    "forge-builder": "./dist/builder/index.js",
    "forge-deployer": "./dist/deployer/index.js",
    "forge-observer": "./dist/observer/index.js",
    "forge-scheduler": "./dist/scheduler/index.js"
  },
  "dependencies": {
    "@forge/build": "workspace:*",
    "@forge/core": "workspace:*",
    "@forge/database": "workspace:*",
    "@forge/git": "workspace:*",
    "@forge/queue": "workspace:*",
    "@forge/types": "workspace:*",
    "eventemitter3": "^5.0.4",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
