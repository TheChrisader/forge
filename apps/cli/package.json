{
  "name": "@forge/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "forge": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "shx chmod +x dist/index.js || echo 'chmod failed - may need to set executable manually'",
    "dev": "tsc --watch",
    "clean": "shx rm -rf dist",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@forge/core": "workspace:*",
    "@forge/types": "workspace:*",
    "axios": "^1.7.9",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "inquirer": "^10.2.2",
    "ora": "^8.1.1",
    "table": "^6.8.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
    "typescript": "^5.7.2"
  }
}
