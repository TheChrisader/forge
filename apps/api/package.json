{
  "name": "@forge/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "clean": "shx rm -rf dist",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@fastify/jwt": "^10.0.0",
    "@fastify/websocket": "^11.2.0",
    "@fastify/compress": "^8.3.1",
    "@fastify/rate-limit": "^10.3.0",
    "fastify": "^5.7.4",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "ioredis": "^5.6.0",
    "bullmq": "^5.46.0",
    "fastify-plugin": "^5.0.0",
    "@forge/core": "workspace:*",
    "@forge/database": "workspace:*",
    "@forge/types": "workspace:*",
    "@forge/queue": "workspace:*",
    "@forge/cache": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "tsx": "^4.21.0"
  }
}
