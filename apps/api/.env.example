# Environment
NODE_ENV=development

# Server
PORT=3000
HOST=localhost

# CORS
CORS_ENABLED=true
CORS_ORIGINS=*
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/forge
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=30000
DB_SSL=false
DB_LOGGING=false

# Redis (Cache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=forge:

# Queue (BullMQ)
QUEUE_HOST=localhost
QUEUE_PORT=6379
QUEUE_PASSWORD=
QUEUE_DB=1
QUEUE_JOB_ATTEMPTS=3
QUEUE_BACKOFF_TYPE=exponential
QUEUE_BACKOFF_DELAY=5000
QUEUE_REMOVE_ON_COMPLETE=10
QUEUE_REMOVE_ON_FAIL=50

# Docker
DOCKER_SOCKET=/var/run/docker.sock
DOCKER_HOST=
DOCKER_PORT=
DOCKER_NETWORK=forge-network
DOCKER_NETWORK_DRIVER=bridge

# Storage
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./data
# S3 (if using s3 provider)
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=

# Proxy
PROXY_PROVIDER=traefik
PROXY_HTTP_PORT=80
PROXY_HTTPS_PORT=443
PROXY_DOMAIN=local.dev
PROXY_SSL_ENABLED=true
PROXY_SSL_AUTO=true

# Observability
LOGS_ENABLED=true
LOG_LEVEL=info
LOG_RETENTION=30d
LOG_FORMAT=pretty
METRICS_ENABLED=true
METRICS_INTERVAL=10000
METRICS_RETENTION=90d
TRACING_ENABLED=false
TRACING_SAMPLING_RATE=0.1
TRACING_ENDPOINT=

# Security
SECRETS_ENCRYPTION_KEY=
SECRETS_ROTATION_DAYS=90
JWT_SECRET=change-this-to-a-secure-random-secret-at-least-32-characters
JWT_EXPIRES_IN=7d
JWT_ISSUER=forge
API_KEY_HEADER=x-api-key
API_KEY_REQUIRED=false
SECURITY_RATE_LIMIT_ENABLED=true
SECURITY_RATE_LIMIT_MAX=1000
SECURITY_RATE_LIMIT_WINDOW=60000

# Features
FEATURE_AUTO_SSL=true
FEATURE_IMAGE_SCAN=true
FEATURE_MULTI_USER=false
FEATURE_PLUGINS=true
FEATURE_WEB_SEARCH=false
FEATURE_HOT_RELOAD=true

# Paths
PATH_DATA=./data
PATH_LOGS=./logs
PATH_BUILDS=./builds
PATH_CACHE=./cache
PATH_PLUGINS=./plugins
PATH_TEMP=./tmp
