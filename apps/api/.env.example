# Environment
NODE_ENV=development

# Server
PORT=4000
HOST=localhost

# CORS
CORS_ENABLED=true
CORS_ORIGINS=*
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Database
DATABASE_URL=postgresql://forge:forge_dev_password@localhost:5432/forge?schema=public
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=30000
DB_SSL=false
DB_LOGGING=false

# Redis (Cache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=forge_dev_password
REDIS_DB=0
REDIS_KEY_PREFIX=forge:

# Queue (BullMQ)
QUEUE_HOST=localhost
QUEUE_PORT=6379
QUEUE_PASSWORD=
QUEUE_DB=1
QUEUE_JOB_ATTEMPTS=3
QUEUE_BACKOFF_TYPE=exponential
QUEUE_BACKOFF_DELAY=5000
QUEUE_REMOVE_ON_COMPLETE=10
QUEUE_REMOVE_ON_FAIL=50

# Docker
DOCKER_SOCKET=/var/run/docker.sock
DOCKER_HOST=
DOCKER_PORT=
DOCKER_NETWORK=forge-network
DOCKER_NETWORK_DRIVER=bridge

# Storage
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./data
# S3 (if using s3 provider)
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=

# Proxy
PROXY_PROVIDER=traefik
PROXY_HTTP_PORT=80
PROXY_HTTPS_PORT=443
PROXY_DOMAIN=forge.localhost
PROXY_SSL_ENABLED=true
PROXY_SSL_MODE=selfsigned
PROXY_SSL_AUTO=true
PROXY_SSL_EMAIL=admin@example.com
PROXY_CERT_PATH=./data/certs

# Observability
LOGS_ENABLED=true
LOG_LEVEL=INFO
LOG_RETENTION=30d
LOG_FORMAT=pretty
METRICS_ENABLED=true
METRICS_INTERVAL=10000
METRICS_RETENTION=90d
TRACING_ENABLED=false
TRACING_SAMPLING_RATE=0.1
TRACING_ENDPOINT=

# Security
SECRETS_ENCRYPTION_KEY=your-encryption-key-min-32-chars
SECRETS_ROTATION_DAYS=90
JWT_SECRET=change-this-to-a-secure-random-secret-at-least-32-characters
JWT_EXPIRES_IN=7d
JWT_ISSUER=forge
API_KEY_HEADER=x-api-key
API_KEY_REQUIRED=false
SECURITY_RATE_LIMIT_ENABLED=true
SECURITY_RATE_LIMIT_MAX=1000
SECURITY_RATE_LIMIT_WINDOW=60000

# Admin Account
ADMIN_EMAIL=admin@forge.local
ADMIN_PASSWORD=forge_admin_password
# Generate with: echo -n "your-password" | sha256sum (Linux/Mac)
# or: printf "your-password" | certutil -encodehash SHA256 (Windows)
ADMIN_PASSWORD_HASH=3a9664b55b5be2ef52f0b740e9fc831f77736bc5e45d054287c52eae6b9ebbe4

# SSE (Server-Sent Events) Configuration
# Enable/disable SSE functionality
SSE_ENABLED=true

# Maximum connections per topic (e.g., per deployment)
SSE_MAX_CONNECTIONS_PER_TOPIC=100

# Maximum total SSE connections across all topics
SSE_MAX_TOTAL_CONNECTIONS=1000

# Connection idle timeout in milliseconds (5 minutes)
# Connections with no activity for this duration will be closed
SSE_CONNECTION_TIMEOUT_MS=300000

# Heartbeat interval in milliseconds (30 seconds)
# NOTE: This is already handled by @fastify/sse plugin in server.ts
# Kept here for potential future customization
SSE_HEARTBEAT_INTERVAL_MS=30000

# Subscriber count threshold for enabling message batching
SSE_BATCH_THRESHOLD=50

# Maximum time to wait before flushing a batch (milliseconds)
SSE_BATCH_WINDOW_MS=50

# Maximum number of messages to accumulate before forcing a flush
SSE_BATCH_MAX_SIZE=100

# Features
FEATURE_AUTO_SSL=true
FEATURE_IMAGE_SCAN=true
FEATURE_MULTI_USER=false
FEATURE_PLUGINS=true
FEATURE_WEB_SEARCH=false
FEATURE_HOT_RELOAD=true

# Paths
PATH_DATA=./data
PATH_LOGS=./logs
PATH_BUILDS=./builds
PATH_CACHE=./cache
PATH_PLUGINS=./plugins
PATH_TEMP=./tmp

# Terminal (interactive container sessions)
TERMINAL_MAX_SESSIONS_PER_USER=5
TERMINAL_IDLE_TIMEOUT_MS=900000
TERMINAL_CLEANUP_INTERVAL_MS=30000
TERMINAL_DEFAULT_SHELL=/bin/bash
TERMINAL_DEFAULT_ROWS=24
TERMINAL_DEFAULT_COLS=80