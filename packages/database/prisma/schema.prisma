// OBSERVABILITY (LOGS, METRICS, TRACING)
// ============================================================================

model Log {
  id         String     @default(uuid()) @db.Uuid
  timestamp  DateTime   @default(now()) @db.Timestamptz
  sourceType SourceType @map("source_type")
  sourceId   String     @map("source_id") @db.Uuid
  sourceName String     @map("source_name") @db.VarChar(255)
  level      LogLevel
  message    String     @db.Text

  context Json? @db.JsonB

  traceId String? @map("trace_id") @db.VarChar(100)
  spanId  String? @map("span_id") @db.VarChar(100)

  projectId    String? @map("project_id") @db.Uuid
  deploymentId String? @map("deployment_id") @db.Uuid
  containerId  String? @map("container_id") @db.Uuid
  serviceId    String? @map("service_id") @db.Uuid

  @@map("logs")
  @@id([id, timestamp])
  @@index([timestamp])
  @@index([sourceType, sourceId])
  @@index([level])
  @@index([traceId])
  @@index([projectId, timestamp])
}

model BuildLog {
  id           String           @default(uuid()) @db.Uuid
  deploymentId String           @map("deployment_id") @db.Uuid
  lineNumber   Int              @map("line_number") @default(0)
  timestamp    DateTime         @default(now()) @db.Timestamptz
  message      String           @db.Text
  level        LogLevel         @default(INFO)
  source       BuildLogSource   @default(BUILD)

  deployment Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)

  @@map("build_logs")
  @@id([id, timestamp])
  @@index([deploymentId, timestamp])
  @@index([timestamp])
  @@index([level])
}

model Metric {
  id         String     @default(uuid()) @db.Uuid
  timestamp  DateTime   @default(now()) @db.Timestamptz
  sourceType SourceType @map("source_type")
  sourceId   String     @map("source_id") @db.Uuid
  sourceName String     @map("source_name") @db.VarChar(255)
  metric     String     @db.VarChar(255)
  value      Float
  unit       String?    @db.VarChar(50)

  labels Json? @db.JsonB

  projectId    String? @map("project_id") @db.Uuid
  containerId  String? @map("container_id") @db.Uuid
  serviceId    String? @map("service_id") @db.Uuid
  deploymentId String? @map("deployment_id") @db.Uuid

  @@map("metrics")
  @@id([id, timestamp])
  @@index([timestamp])
  @@index([sourceType, sourceId])
  @@index([metric])
  @@index([projectId, timestamp])
}

model TracingConfig {
  id             String         @id @default(uuid()) @db.Uuid
  projectId      String         @unique @map("project_id") @db.Uuid
  enabled        Boolean        @default(false)
  backend        TracingBackend
  endpoint       String         @db.VarChar(500)
  sampleRate     Float          @default(0.1) @map("sample_rate")
  captureHeaders String[]       @default([]) @map("capture_headers")
  autoInstrument Boolean        @default(true) @map("auto_instrument")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("tracing_configs")
}

// ============================================================================
// ALERTING
// ============================================================================

model AlertRule {
  id          String        @id @default(uuid()) @db.Uuid
  projectId   String        @map("project_id") @db.Uuid
  name        String        @db.VarChar(255)
  description String?       @db.Text
  metric      String        @db.VarChar(255)
  operator    AlertOperator
  threshold   Float
  duration    Int
  severity    AlertSeverity
  sourceType  SourceType?   @map("source_type")
  sourceId    String?       @map("source_id") @db.Uuid
  enabled     Boolean       @default(true)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz
  createdBy String?  @map("created_by") @db.Uuid

  project  Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  alerts   Alert[]
  channels AlertChannelRule[]

  @@map("alert_rules")
  @@index([projectId])
  @@index([enabled])
}

model Alert {
  id       String        @id @default(uuid()) @db.Uuid
  ruleId   String        @map("rule_id") @db.Uuid
  status   AlertStatus
  severity AlertSeverity
  value    Float
  message  String        @db.Text

  firedAt    DateTime  @default(now()) @map("fired_at") @db.Timestamptz
  resolvedAt DateTime? @map("resolved_at") @db.Timestamptz

  acknowledgedAt DateTime? @map("acknowledged_at") @db.Timestamptz
  acknowledgedBy String?   @map("acknowledged_by") @db.Uuid

  rule          AlertRule           @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  notifications AlertNotification[]

  @@map("alerts")
  @@index([ruleId])
  @@index([status])
  @@index([firedAt])
}

model AlertChannel {
  id        String      @id @default(uuid()) @db.Uuid
  projectId String?     @map("project_id") @db.Uuid
  name      String      @db.VarChar(255)
  type      ChannelType
  config    Json        @db.JsonB
  enabled   Boolean     @default(true)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  project       Project?            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  rules         AlertChannelRule[]
  notifications AlertNotification[]

  @@map("alert_channels")
  @@index([projectId])
  @@index([type])
}

model AlertChannelRule {
  id         String          @id @default(uuid()) @db.Uuid
  ruleId     String          @map("rule_id") @db.Uuid
  channelId  String          @map("channel_id") @db.Uuid
  severities AlertSeverity[]

  rule    AlertRule    @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  channel AlertChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([ruleId, channelId])
  @@map("alert_channel_rules")
}

model AlertNotification {
  id        String             @default(uuid()) @db.Uuid
  timestamp DateTime           @default(now()) @db.Timestamptz
  alertId   String             @map("alert_id") @db.Uuid
  channelId String             @map("channel_id") @db.Uuid
  status    NotificationStatus

  sentAt DateTime? @map("sent_at") @db.Timestamptz
  error  String?   @db.Text

  alert   Alert        @relation(fields: [alertId], references: [id], onDelete: Cascade)
  channel AlertChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@map("alert_notifications")
  @@id([id, timestamp])
  @@index([alertId])
  @@index([status])
}

// ============================================================================
// JOBS & AUTOMATION
// ============================================================================

model Job {
  id          String     @id @default(uuid()) @db.Uuid
  projectId   String     @map("project_id") @db.Uuid
  name        String     @db.VarChar(255)
  description String?    @db.Text
  command     String     @db.Text
  schedule    String?    @db.VarChar(100)
  status      JobStatus  @default(IDLE)
  enabled     Boolean    @default(true)

  lastRunAt     DateTime?     @map("last_run_at") @db.Timestamptz
  lastRunStatus JobRunStatus? @map("last_run_status")
  nextRunAt     DateTime?     @map("next_run_at") @db.Timestamptz

  timeout    Int? @default(3600)
  retries    Int  @default(0)
  retryDelay Int  @default(60) @map("retry_delay")

  env Json? @db.JsonB

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  createdBy String?   @map("created_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  runs    JobRun[]

  @@map("jobs")
  @@index([projectId])
  @@index([schedule])
  @@index([nextRunAt])
  @@index([enabled])
  @@index([env(ops: JsonbPathOps)], type: Gin)
}

model JobRun {
  id          String       @id @default(uuid()) @db.Uuid
  jobId       String       @map("job_id") @db.Uuid
  status      JobRunStatus @default(RUNNING)
  startedAt   DateTime     @default(now()) @map("started_at") @db.Timestamptz
  completedAt DateTime?    @map("completed_at") @db.Timestamptz
  output      String?      @db.Text
  error       String?      @db.Text
  exitCode    Int?         @map("exit_code")
  triggeredBy TriggerType  @map("triggered_by")

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("job_runs")
  @@index([jobId, startedAt])
  @@index([status])
}

