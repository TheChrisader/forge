// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id        String   @id @default(uuid())
  name      String   @unique
  type      String?
  status    String   @default("inactive") // active, inactive, archived

  config    Json     @default("{}")
  metadata  Json     @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?

  deployments Deployment[]
  containers    Container[]

  @@index([name])
  @@index([createdAt])
  @@index([status])
}

model Deployment {
  id        String   @id @default(uuid())
  projectId String
  version   String
  status    String   // pending, building, deploying, running, failed
  
  buildStartedAt    DateTime?
  buildCompletedAt  DateTime?
  buildImage        String?
  buildLogs         String?
  
  deployStartedAt   DateTime?
  deployCompletedAt DateTime?
  
  error     String?

  createdAt DateTime @default(now())
  createdBy String?
  updatedBy String?

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  containers Container[]

  @@index([projectId])
  @@index([status])
  @@index([createdAt])
}

model Container {
  id           String   @id @default(uuid())
  projectId    String
  deploymentId String

  name         String?  // Human-readable container name (e.g., "app-container-1")
  containerId  String   @unique // Docker container ID
  image        String
  status       String   // creating, running, stopped, error

  config       Json     @default("{}")
  ports        Json?    // Port mappings: [{containerPort: 80, hostPort: 8080, protocol: "tcp"}]
  volumes      Json?    // Volume mounts: [{source: "/host/path", target: "/container/path"}]
  network      String?   // Network name
  env          Json?    // Environment variables: {NODE_ENV: "production", PORT: "8080"}

  healthStatus String?  // healthy, unhealthy, starting
  healthChecks Int      @default(0)
  healthFails  Int      @default(0)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  startedAt    DateTime?
  stoppedAt    DateTime?
  deletedAt    DateTime? // Soft delete support
  createdBy    String?
  updatedBy    String?

  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deployment   Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([deploymentId])
  @@index([containerId])
  @@index([name])
  @@index([status])
  @@index([network])
}