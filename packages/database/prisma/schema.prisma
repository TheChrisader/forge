  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  lastAccessedAt DateTime? @map("last_accessed_at") @db.Timestamptz
  accessCount    Int       @default(0) @map("access_count")

  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  project                    Project?    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  registriesUsingAsPassword  Registry[]  @relation("RegistryPassword")
  registriesUsingAsToken     Registry[]  @relation("RegistryToken")

  @@unique([projectId, key])
  @@map("secrets")
  @@index([projectId])
  @@index([key])
  @@index([createdBy])
}

model EnvironmentVariable {
  id            String  @id @default(uuid()) @db.Uuid
  projectId     String  @map("project_id") @db.Uuid
  environmentId String? @map("environment_id") @db.Uuid
  key           String  @db.VarChar(255)
  value         String  @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environment Environment? @relation(fields: [environmentId], references: [id])

  @@unique([projectId, environmentId, key])
  @@map("environment_variables")
  @@index([projectId])
  @@index([environmentId])
}

