  source      String     @db.VarChar(500)
  target      String     @db.VarChar(500)
  mode        VolumeMode @default(RW)

  container Container @relation(fields: [containerId], references: [id], onDelete: Cascade)

  @@map("volume_mappings")
  @@index([containerId])
}

model HealthCheckConfig {
  id          String @id @default(uuid()) @db.Uuid
  containerId String @unique @map("container_id") @db.Uuid
  test        String @db.VarChar(500)
  interval    Int    @default(30)
  timeout     Int    @default(5)
  retries     Int    @default(3)
  startPeriod Int    @default(0) @map("start_period")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  container Container @relation(fields: [containerId], references: [id], onDelete: Cascade)

  @@map("health_check_configs")
  @@index([containerId])
}

model NetworkAttachment {
  id          String  @id @default(uuid()) @db.Uuid
  containerId String  @map("container_id") @db.Uuid
  networkName String  @map("network_name") @db.VarChar(255)
  ipAddress   String? @map("ip_address") @db.VarChar(45)
  macAddress  String? @map("mac_address") @db.VarChar(17)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  container Container @relation(fields: [containerId], references: [id], onDelete: Cascade)

  @@map("network_attachments")
  @@index([containerId])
  @@index([networkName])
}

model ResourceLimit {
  id             String  @id @default(uuid()) @db.Uuid
  containerId    String  @unique @map("container_id") @db.Uuid
  cpuRequest     Float?  @map("cpu_request")
  memoryRequest  BigInt? @map("memory_request")
  cpuLimit       Float?  @map("cpu_limit")
  memoryLimit    BigInt? @map("memory_limit")
  storageLimit   BigInt? @map("storage_limit")
  bandwidthLimit BigInt? @map("bandwidth_limit")

  container Container @relation(fields: [containerId], references: [id], onDelete: Cascade)

  @@map("resource_limits")
}

// ============================================================================
// SERVICES (Database, Cache, Queue, etc.)
// ============================================================================

model Service {
  id        String        @id @default(uuid()) @db.Uuid
  projectId String        @map("project_id") @db.Uuid
  name      String        @db.VarChar(255)
  type      ServiceType
  engine    String?       @db.VarChar(100)
  status    ServiceStatus @default(CREATING)

  config Json @default("{}") @db.JsonB

  connectionHost     String? @map("connection_host") @db.VarChar(255)
  connectionPort     Int?    @map("connection_port")
  connectionUrl      String? @map("connection_url") @db.Text
  connectionUsername String? @map("connection_username") @db.VarChar(255)
  connectionPassword String? @map("connection_password") @db.Text
  connectionDatabase String? @map("connection_database") @db.VarChar(255)

  version          String? @map("version") @db.VarChar(50)
  internalHostname String? @map("internal_hostname") @db.VarChar(255)
  volumeName       String? @map("volume_name") @db.VarChar(255)
  containerId      String? @map("container_id") @db.VarChar(100)

  isShared              Boolean  @default(false) @map("is_shared")
  autoBackupSchedule    String?  @map("auto_backup_schedule") @db.VarChar(100)
  autoBackupRetention   Int?     @map("auto_backup_retention")

  resourcesAllocated Json? @map("resources_allocated") @db.JsonB

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  createdBy String?   @map("created_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  project       Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  backups       ServiceBackup[]
  projectAccess ServiceProjectAccess[]

  @@map("services")
  @@unique([projectId, name])
  @@index([projectId])
  @@index([type])
  @@index([status])
  @@index([deletedAt])
}

model ServiceBackup {
  id        String       @id @default(uuid()) @db.Uuid
  serviceId String       @map("service_id") @db.Uuid
  type      BackupType
  path      String       @db.VarChar(500)
  size      BigInt
  status    BackupStatus

  startedAt   DateTime? @map("started_at") @db.Timestamptz
  completedAt DateTime? @map("completed_at") @db.Timestamptz

  metadata Json?   @db.JsonB
  error    String? @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  createdBy String?  @map("created_by") @db.Uuid

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@map("service_backups")
  @@index([serviceId, createdAt])
  @@index([status])
}

model ServiceProjectAccess {
  id        String   @id @default(uuid()) @db.Uuid
  serviceId String   @map("service_id") @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  linkedAt  DateTime @default(now()) @map("linked_at") @db.Timestamptz
  linkedBy  String?  @map("linked_by") @db.Uuid

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([serviceId, projectId])
  @@index([projectId])
  @@map("service_project_access")
}

// ============================================================================
// SECRETS & ENVIRONMENT VARIABLES
// ============================================================================

model Secret {
  id             String  @id @default(uuid()) @db.Uuid
  projectId      String? @map("project_id") @db.Uuid
  key            String  @db.VarChar(255)
  encryptedValue String  @map("encrypted_value") @db.Text
  encryptionKeyId String @map("encryption_key_id") @db.VarChar(100)
