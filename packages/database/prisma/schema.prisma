// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}


datasource db {
  provider = "postgresql"
}

// ============================================================================
// ENUMS
// ============================================================================

enum ProjectStatus {
  ACTIVE
  INACTIVE
  ARCHIVED

  @@map("project_status")
}

enum DeploymentStatus {
  PENDING
  QUEUED
  BUILDING
  DEPLOYING
  ROLLBACK
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
  TIMED_OUT
  STOPPED

  @@map("deployment_status")
}

enum DeploymentStrategy {
  ROLLING
  BLUE_GREEN
  CANARY
  RECREATE

  @@map("deployment_strategy")
}

enum ActiveEnvironment {
  BLUE
  GREEN

  @@map("active_environment")
}

enum ContainerStatus {
  CREATING
  STARTING
  RUNNING
  HEALTHY
  UNHEALTHY
  STOPPING
  STOPPED
  RESTARTING
  TERMINATED
  ERROR

  @@map("container_status")
}

enum HealthStatus {
  HEALTHY
  UNHEALTHY
  STARTING

  @@map("health_status")
}

enum PortProtocol {
  TCP
  UDP

  @@map("port_protocol")
}

enum VolumeMode {
  RW
  RO

  @@map("volume_mode")
}

enum LogLevel {
  TRACE
  DEBUG
  INFO
  WARN
  ERROR
  FATAL

  @@map("log_level")
}

enum BuildLogSource {
  BUILD    // Build system output (docker build, npm run build, etc.)
  SYSTEM   // System-level messages (worker events, state changes)
  USER     // User-initiated actions
  DEPLOY   // Deployment runtime logs

  @@map("build_log_source")
}

enum SourceType {
  CONTAINER
  SERVICE
  SYSTEM
  BUILD
  DEPLOYMENT

  @@map("source_type")
}

enum SslStatus {
  PENDING
  ACTIVE
  EXPIRED
  FAILED

  @@map("ssl_status")
}

enum GitProvider {
  GITHUB
  GITLAB
  BITBUCKET

  @@map("git_provider")
}

enum WebhookEvent {
  DEPLOYMENT_CREATED
  DEPLOYMENT_BUILDING
  DEPLOYMENT_READY
  DEPLOYMENT_ERROR
  DEPLOYMENT_CANCELLED
  DOMAIN_VERIFIED
  DOMAIN_FAILED

  @@map("webhook_event")
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER

  @@map("team_role")
}

enum ServiceType {
  DATABASE
  CACHE
  QUEUE
  STORAGE
  SEARCH
  MONITORING
  CUSTOM

  @@map("service_type")
}

enum ServiceStatus {
  CREATING
  STARTING
  RUNNING
  HEALTHY
  UNHEALTHY
  STOPPING
  STOPPED
  ERROR
  UPGRADING
  BACKING_UP
  RESTORING

  @@map("service_status")
}

enum BackupType {
  MANUAL
  SCHEDULED
  PRE_UPGRADE

  @@map("backup_type")
}

enum BackupStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED

  @@map("backup_status")
}

enum RegistryType {
  DOCKER_HUB
  GHCR
  ECR
  GCR
  ACR
  HARBOR
  QUAY
  SELF_HOSTED

  @@map("registry_type")
}

enum ScanStatus {
  PENDING
  SCANNING
  COMPLETED
  FAILED

  @@map("scan_status")
}

enum Severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  NEGLIGIBLE

  @@map("severity")
}

enum JobStatus {
  IDLE
  RUNNING

  @@map("job_status")
}

enum JobRunStatus {
  RUNNING
  SUCCESS
  FAILED
  TIMEOUT
  CANCELLED

  @@map("job_run_status")
}

enum TriggerType {
  SCHEDULED
  MANUAL
  WEBHOOK
  DEPLOYMENT

  @@map("trigger_type")
}

enum AlertOperator {
  GREATER_THAN
  LESS_THAN
  EQUALS
  NOT_EQUALS

  @@map("alert_operator")
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL

  @@map("alert_severity")
}

enum AlertStatus {
  FIRING
  RESOLVED
  ACKNOWLEDGED

  @@map("alert_status")
}

enum ChannelType {
  EMAIL
  SLACK
  PAGERDUTY
  WEBHOOK
  SMS
  DISCORD
  TEAMS
  PUSH

  @@map("channel_type")
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED

  @@map("notification_status")
}

enum IntegrationType {
  AWS_S3
  GCS
  AZURE_BLOB
  CLOUDFLARE_R2
  BACKBLAZE_B2
  DATADOG
  NEW_RELIC
  SENTRY
  SLACK
  DISCORD
  PAGERDUTY
  GITHUB_ACTIONS
  GITLAB_CI
  CIRCLE_CI
  SENDGRID
  MAILGUN
  SES
  CLOUDFLARE_DNS
  ROUTE53
  CUSTOM

  @@map("integration_type")
}

enum PolicyAction {
  ALLOW
  DENY

  @@map("policy_action")
}

enum TracingBackend {
  JAEGER
  ZIPKIN
  TEMPO
  LIGHTSTEP
  HONEYCOMB
  DATADOG

  @@map("tracing_backend")
}

// ============================================================================
// USER & TEAM MANAGEMENT
// ============================================================================

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_INVITE
  DELETED

  @@map("user_status")
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique @db.VarChar(255)
  name         String?   @db.VarChar(255)
  avatarUrl    String?   @map("avatar_url") @db.VarChar(500)
  passwordHash String?   @map("password_hash") @db.VarChar(255)
  status       UserStatus @default(ACTIVE)
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz
  loginCount   Int       @default(0) @map("login_count")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  teamMemberships TeamMember[]
  roleAssignments RoleAssignment[]
  apiKeys         ApiKey[]
  auditLogs       AuditLog[]
  refreshTokens   RefreshToken[]
  invitations     Invitation[] @relation("InvitedBy")
  passwordResetTokens PasswordResetToken[]
  pushSubscriptions   PushSubscription[]

  @@map("users")
  @@index([email])
  @@index([status])
}

model Team {
  id   String @id @default(uuid()) @db.Uuid
  name String @db.VarChar(255)
  slug String @unique @db.VarChar(100)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  members      TeamMember[]
  projects     Project[]
  invitations  Invitation[]

  @@map("teams")
  @@index([slug])
}

model TeamMember {
  id     String   @id @default(uuid()) @db.Uuid
  teamId String   @map("team_id") @db.Uuid
  userId String   @map("user_id") @db.Uuid
  role   TeamRole @default(MEMBER)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("team_members")
  @@index([teamId])
  @@index([userId])
}

// ============================================================================
// RBAC (ROLE-BASED ACCESS CONTROL)
// ============================================================================

model Role {
  id          String  @id @default(uuid()) @db.Uuid
  name        String  @unique @db.VarChar(100) // OWNER, ADMIN, MEMBER, VIEWER
  description String? @db.Text
  isSystem    Boolean @default(false) @map("is_system")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  permissions RolePermission[]
  assignments RoleAssignment[]

  @@map("roles")
}

model Permission {
  id          String  @id @default(uuid()) @db.Uuid
  resource    String  @db.VarChar(100)
  action      String  @db.VarChar(100)
  description String? @db.Text

  roles RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  id           String @id @default(uuid()) @db.Uuid
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model RoleAssignment {
  id           String  @id @default(uuid()) @db.Uuid
  userId       String  @map("user_id") @db.Uuid
  roleId       String  @map("role_id") @db.Uuid
  resourceType String? @map("resource_type") @db.VarChar(100)
  resourceId   String? @map("resource_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  createdBy String?  @map("created_by") @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, resourceType, resourceId])
  @@map("role_assignments")
  @@index([userId])
  @@index([resourceType, resourceId])
}

// ============================================================================
// AUTH TOKENS & INVITATIONS
// ============================================================================

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(255)
  deviceId String?   @map("device_id") @db.VarChar(255)
  userAgent String?  @map("user_agent") @db.Text
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
}

model Invitation {
  id         String   @id @default(uuid()) @db.Uuid
  email      String   @db.VarChar(255)
  teamId     String   @map("team_id") @db.Uuid
  role       TeamRole @default(MEMBER)
  tokenHash  String   @unique @map("token_hash") @db.VarChar(255)
  invitedBy  String   @map("invited_by") @db.Uuid
  expiresAt  DateTime @map("expires_at") @db.Timestamptz
  acceptedAt DateTime? @map("accepted_at") @db.Timestamptz
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  team       Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  invitedByUser User @relation("InvitedBy", fields: [invitedBy], references: [id])

  @@map("invitations")
  @@index([email])
  @@index([teamId])
  @@index([tokenHash])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  usedAt    DateTime? @map("used_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
}

// ============================================================================
// PUSH NOTIFICATIONS
// ============================================================================

model PushSubscription {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  endpoint  String   @db.VarChar(500)
  p256dh    String   @db.VarChar(255)
  auth      String   @db.VarChar(255)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@map("push_subscriptions")
  @@index([userId])
}

// ============================================================================
// PROJECTS & ENVIRONMENTS
// ============================================================================

model Project {
  id         String        @id @default(uuid()) @db.Uuid
  name       String        @unique @db.VarChar(255)
  teamId     String?       @map("team_id") @db.Uuid
  type       String?       @db.VarChar(100)
  sourceType String?       @map("source_type") @db.VarChar(100)
  sourceUrl  String?       @map("source_url") @db.Text
  status     ProjectStatus @default(INACTIVE)

  config   Json @default("{}") @db.JsonB
  metadata Json @default("{}") @db.JsonB

  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid

  team                Team?                 @relation(fields: [teamId], references: [id])
  deployments         Deployment[]
  containers          Container[]
  environments        Environment[]
  domains             Domain[]
  environmentVars     EnvironmentVariable[]
  gitIntegration      GitIntegration?
  webhooks            Webhook[]
  buildCaches         BuildCache[]
  services            Service[]
  linkedServices      ServiceProjectAccess[]
  secrets             Secret[]
  jobs                Job[]
  images              Image[]
  alertRules          AlertRule[]
  alertChannels       AlertChannel[]
  integrations        Integration[]
  networkPolicies     NetworkPolicy[]
  tracingConfig       TracingConfig?

  @@map("projects")
  @@index([name])
  @@index([teamId])
  @@index([createdAt])
  @@index([status])
  @@index([createdBy])
  @@index([deletedAt])
  @@index([config(ops: JsonbPathOps)], type: Gin)
  @@index([metadata(ops: JsonbPathOps)], type: Gin)
}

model Environment {
  id           String  @id @default(uuid()) @db.Uuid
  projectId    String  @map("project_id") @db.Uuid
  name         String  @db.VarChar(100)
  slug         String  @db.VarChar(100)
  isProduction Boolean @default(false) @map("is_production")
  isDefault    Boolean @default(false) @map("is_default")
  autoDeploy   Boolean @default(false) @map("auto_deploy")
  branch       String? @db.VarChar(255)
  domain       String? @db.VarChar(255)
  subdomain    String? @db.VarChar(255)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  project     Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deployments Deployment[]
  variables   EnvironmentVariable[]

  @@unique([projectId, slug])
  @@map("environments")
  @@index([projectId])
}

// ============================================================================
// CONTAINER REGISTRY & IMAGES
// ============================================================================

model Registry {
  id       String       @id @default(uuid()) @db.Uuid
  name     String       @db.VarChar(255)
  type     RegistryType
  url      String       @db.VarChar(500)
  username String?      @db.VarChar(255)

  passwordSecretId String? @map("password_secret_id") @db.Uuid
  tokenSecretId    String? @map("token_secret_id") @db.Uuid

  isDefault  Boolean @default(false) @map("is_default")
  isPublic   Boolean @default(false) @map("is_public")
  scanOnPush Boolean @default(true) @map("scan_on_push")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  images         Image[]
  passwordSecret Secret? @relation("RegistryPassword", fields: [passwordSecretId], references: [id])
  tokenSecret    Secret? @relation("RegistryToken", fields: [tokenSecretId], references: [id])

  @@map("registries")
  @@index([type])
  @@index([isDefault])
}

model Image {
  id           String      @id @default(uuid()) @db.Uuid
  registryId   String      @map("registry_id") @db.Uuid
  projectId    String?     @map("project_id") @db.Uuid
  repository   String      @db.VarChar(500)
  tag          String      @db.VarChar(255)
  digest       String      @db.VarChar(100)
  fullName     String      @map("full_name") @db.VarChar(1000)
  size         BigInt
  architecture String      @db.VarChar(50)
  os           String      @db.VarChar(50)
  buildId      String?     @map("build_id") @db.Uuid
  scanStatus   ScanStatus? @map("scan_status")
  scanResults  Json?       @map("scan_results") @db.JsonB

  pushedAt     DateTime  @default(now()) @map("pushed_at") @db.Timestamptz
  lastPulledAt DateTime? @map("last_pulled_at") @db.Timestamptz

  registry        Registry        @relation(fields: [registryId], references: [id], onDelete: Cascade)
  project         Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  vulnerabilities Vulnerability[]

  @@unique([registryId, repository, tag])
  @@unique([digest])
  @@map("images")
  @@index([projectId])
  @@index([scanStatus])
}

model Vulnerability {
  id           String   @id @default(uuid()) @db.Uuid
  imageId      String   @map("image_id") @db.Uuid
  cveId        String?  @map("cve_id") @db.VarChar(50)
  severity     Severity
  package      String   @db.VarChar(255)
  version      String   @db.VarChar(100)
  fixAvailable Boolean  @default(false) @map("fix_available")
  fixedVersion String?  @map("fixed_version") @db.VarChar(100)
  description  String?  @db.Text
  link         String?  @db.VarChar(500)

  detectedAt DateTime @default(now()) @map("detected_at") @db.Timestamptz

  image Image @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@map("vulnerabilities")
  @@index([imageId])
  @@index([severity])
  @@index([cveId])
}

// ============================================================================
// DEPLOYMENTS
// ============================================================================

model Deployment {
  id            String           @id @default(uuid()) @db.Uuid
  projectId     String           @map("project_id") @db.Uuid
  environmentId String?          @map("environment_id") @db.Uuid
  status        DeploymentStatus
  strategy      DeploymentStrategy @default(ROLLING)

  buildStartedAt   DateTime? @map("build_started_at") @db.Timestamptz
  buildCompletedAt DateTime? @map("build_completed_at") @db.Timestamptz
  buildImage       String?   @map("build_image") @db.VarChar(500)

  deployStartedAt   DateTime? @map("deploy_started_at") @db.Timestamptz
  deployCompletedAt DateTime? @map("deploy_completed_at") @db.Timestamptz

  // Blue-green specific
  blueEnvironmentId  String?             @map("blue_environment_id") @db.Uuid
  greenEnvironmentId String?             @map("green_environment_id") @db.Uuid
  activeEnvironment  ActiveEnvironment?  @map("active_environment")

  // Canary specific
  canaryPercentage Int?  @map("canary_percentage")
  canaryMetrics    Json? @map("canary_metrics") @db.JsonB

  // Rollback
  canRollback    Boolean   @default(true) @map("can_rollback")
  rolledBackAt   DateTime? @map("rolled_back_at") @db.Timestamptz
  rollbackReason String?   @map("rollback_reason") @db.Text

  error String? @db.Text

  parentId  String?   @map("parent_id") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid

  parent      Deployment?         @relation("DeploymentChain", fields: [parentId], references: [id])
  children    Deployment[]        @relation("DeploymentChain")
  project     Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environment Environment?        @relation(fields: [environmentId], references: [id])
  containers  Container[]
  buildLogs   BuildLog[]
  urls        DeploymentUrl[]
  gitCommit   GitCommit?
  metrics     DeploymentMetrics[]
  comments    DeploymentComment[]

  @@map("deployments")
  @@index([projectId])
  @@index([environmentId])
  @@index([status])
  @@index([createdAt])
  @@index([createdBy])
  @@index([parentId])
  @@index([deletedAt])
}

model DeploymentUrl {
  id           String  @id @default(uuid()) @db.Uuid
  deploymentId String  @map("deployment_id") @db.Uuid
  url          String  @unique @db.VarChar(500)
  isPreview    Boolean @default(true) @map("is_preview")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  deployment Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)

  @@map("deployment_urls")
  @@index([deploymentId])
}

model DeploymentMetrics {
  id           String @id @default(uuid()) @db.Uuid
  deploymentId String @map("deployment_id") @db.Uuid

  buildTime    Int?    @map("build_time")
  deployTime   Int?    @map("deploy_time")
  bundleSize   BigInt? @map("bundle_size")

  requestCount BigInt @default(0) @map("request_count")
  errorCount   BigInt @default(0) @map("error_count")
  bandwidth    BigInt @default(0)

  recordedAt DateTime @default(now()) @map("recorded_at") @db.Timestamptz

  deployment Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)

  @@map("deployment_metrics")
  @@index([deploymentId, recordedAt])
}

model DeploymentComment {
  id           String @id @default(uuid()) @db.Uuid
  deploymentId String @map("deployment_id") @db.Uuid
  userId       String @map("user_id") @db.Uuid
  content      String @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  deployment Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)

  @@map("deployment_comments")
  @@index([deploymentId])
  @@index([userId])
}

// ============================================================================
// CONTAINERS
// ============================================================================

model Container {
  id              String          @id @default(uuid()) @db.Uuid
  projectId       String          @map("project_id") @db.Uuid
  deploymentId    String          @map("deployment_id") @db.Uuid
  name            String?         @db.VarChar(255)
  containerId     String          @unique @map("container_id") @db.VarChar(100)
  image           String          @db.VarChar(500)
  status          ContainerStatus @default(CREATING)
  containerNumber Int             @default(1) @map("container_number")

  config Json  @default("{}") @db.JsonB
  env    Json? @db.JsonB

  healthStatus      HealthStatus? @map("health_status")
  healthChecks      Int           @default(0) @map("health_checks")
  healthFails       Int           @default(0) @map("health_fails")
  lastHealthCheckAt DateTime?     @map("last_health_check_at") @db.Timestamptz

  replacedById String? @map("replaced_by_id") @db.Uuid

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  startedAt DateTime? @map("started_at") @db.Timestamptz
  stoppedAt DateTime? @map("stopped_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  replacedBy         Container?          @relation("ContainerReplacement", fields: [replacedById], references: [id])
  replaces           Container[]         @relation("ContainerReplacement")
  project            Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deployment         Deployment          @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
  ports              PortMapping[]
  volumes            VolumeMapping[]
  healthCheckConfig  HealthCheckConfig?
  networkAttachments NetworkAttachment[]
  resourceLimit      ResourceLimit?

  @@map("containers")
  @@index([projectId])
  @@index([deploymentId])
  @@index([containerId])
  @@index([name])
  @@index([status])
  @@index([createdBy])
  @@index([config(ops: JsonbPathOps)], type: Gin)
  @@index([env(ops: JsonbPathOps)], type: Gin)
}

model PortMapping {
