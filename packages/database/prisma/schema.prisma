// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}


datasource db {
  provider = "postgresql"
}

// =============================================================================
// Enums
// =============================================================================

enum ProjectStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum DeploymentStatus {
  PENDING
  BUILDING
  DEPLOYING
  RUNNING
  FAILED
}

enum ContainerStatus {
  CREATING
  STARTING
  RUNNING
  STOPPING
  STOPPED
  TERMINATED
  ERROR
}

enum HealthStatus {
  HEALTHY
  UNHEALTHY
  STARTING
}

enum PortProtocol {
  TCP
  UDP
}

enum VolumeMode {
  RW
  RO
}

// =============================================================================
// Models
// =============================================================================

model Project {
  id        String        @id @default(uuid())
  name      String        @unique
  type      String?        // Legacy: consider using sourceType instead
  sourceType String?      // e.g., "registry", "docker-compose", "git", "dockerfile"
  sourceUrl  String?      // e.g., "ghcr.io/user/repo", "git@github.com:..."
  status    ProjectStatus @default(INACTIVE)

  config    Json     @default("{}") /// @zod.custom.use(z.record(z.string(), z.unknown()))
  metadata  Json     @default("{}") /// @zod.custom.use(z.record(z.string(), z.unknown()))

  deletedAt DateTime?     // Soft delete support

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?

  deployments Deployment[]
  containers    Container[]

  @@index([name])
  @@index([createdAt])
  @@index([status])
  @@index([createdBy])
  @@index([deletedAt])
}

model Deployment {
  id        String           @id @default(uuid())
  projectId String
  version   String
  status    DeploymentStatus

  buildStartedAt    DateTime?
  buildCompletedAt  DateTime?
  buildImage        String?
  buildLogs         String?

  deployStartedAt   DateTime?
  deployCompletedAt DateTime?

  error     String?

  parentId  String?
  parent    Deployment?      @relation("DeploymentChain", fields: [parentId], references: [id])
  children Deployment[]      @relation("DeploymentChain")

  createdAt DateTime @default(now())
  createdBy String?
  updatedBy String?

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  containers Container[]

  @@index([projectId])
  @@index([status])
  @@index([createdAt])
  @@index([createdBy])
  @@index([parentId])
  @@unique([projectId, version])
}

model PortMapping {
  id             String        @id @default(uuid())
  containerId    String

  containerPort  Int
  hostPort       Int?
  protocol       PortProtocol  @default(TCP)

  container      Container     @relation(fields: [containerId], references: [id], onDelete: Cascade)

  @@index([containerId])
  @@index([hostPort, protocol])
}

model VolumeMapping {
  id          String       @id @default(uuid())
  containerId String

  source      String
  target      String
  mode        VolumeMode   @default(RW)

  container   Container    @relation(fields: [containerId], references: [id], onDelete: Cascade)

  @@index([containerId])
}

model HealthCheckConfig {
  id          String   @id @default(uuid())
  containerId String   @unique

  test        String   // e.g., "curl -f http://localhost:3000/health"
  interval    Int      @default(30)  // seconds
  timeout     Int      @default(5)   // seconds
  retries     Int      @default(3)   // failures before unhealthy
  startPeriod Int      @default(0)   // grace period

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  container   Container @relation(fields: [containerId], references: [id], onDelete: Cascade)

  @@index([containerId])
}

model NetworkAttachment {
  id          String   @id @default(uuid())
  containerId String

  networkName String   // e.g., "bridge", "mynetwork"
  ipAddress   String?  // assigned IP
  macAddress  String?  // assigned MAC

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  container   Container @relation(fields: [containerId], references: [id], onDelete: Cascade)

  @@index([containerId])
  @@index([networkName])
}

model Container {
  id           String   @id @default(uuid())
  projectId    String
  deploymentId String

  name         String?   // Human-readable container name (e.g., "app-container-1")
  containerId  String   @unique // Docker container ID
  image        String
  status       ContainerStatus @default(CREATING)
  containerNumber Int     @default(1)  // Instance number for replicas (1, 2, 3...)

  config       Json     @default("{}")
  ports        PortMapping[]
  volumes      VolumeMapping[]
  env          Json?

  healthStatus HealthStatus?
  healthChecks Int             @default(0)
  healthFails  Int             @default(0)
  lastHealthCheckAt DateTime?

  replacedById String?
  replacedBy   Container? @relation("ContainerReplacement", fields: [replacedById], references: [id])
  replaces     Container[] @relation("ContainerReplacement")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  startedAt    DateTime?
  stoppedAt    DateTime?
  deletedAt    DateTime? // Soft delete support
  createdBy    String?
  updatedBy    String?

  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deployment   Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
  healthCheckConfig HealthCheckConfig?
  networkAttachments NetworkAttachment[]

  @@index([projectId])
  @@index([deploymentId])
  @@index([containerId])
  @@index([name])
  @@index([status])
  @@index([createdBy])
}