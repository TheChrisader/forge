{
  "name": "@forge/database",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "prebuild": "shx rm -rf dist tsconfig.tsbuildinfo",
    "build": "tsc",
    "dev": "tsc --watch",
    "postbuild": "shx mkdir -p dist/generated && shx cp -r src/generated/client dist/generated/client",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force",
    "test:connection": "tsx src/test-connection.ts"
  },
  "devDependencies": {
    "prisma": "^7.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "pg": "^8.18.0",
    "zod": "^4.3.6"
  }
}
